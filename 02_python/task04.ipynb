   "source": [
    "try:\n",
    "    num1 = float(input(\"1つ目の数を入力してください: \"))\n",
    "    num2 = float(input(\"2つ目の数を入力してください: \"))\n",
    "\n",
    "    result = num1 / num2\n",
    "    \n",
    "    print(f\"計算結果: {result}\")\n",
    "\n",
    "except ValueError:\n",
    "    print(\"エラー: 数値を入力してください\")\n",
    "\n",
    "except ZeroDivisionError:\n",
    "    print(\"エラー: 0で割ることはできません\")"
   ]
  }
